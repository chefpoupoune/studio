rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Autorise la lecture et l'écriture sur tous les documents
    // pour n'importe quel utilisateur (authentifié ou non).
    // ATTENTION : Ceci est pour le développement uniquement.
    // NE PAS UTILISER EN PRODUCTION SANS SÉCURISER VOS RÈGLES.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
